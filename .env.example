################################
# Docker Compose Configuration #
################################

POSTGRES_USER=admin
POSTGRES_PASSWORD=admin12345
POSTGRES_DB=h2_trust
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin12345
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin12345

#############################
# Application Configuration #
#############################

LOG_LEVEL=fatal,error,warn,log,debug
API_PORT=3000
SWAGGER_PATH=api
PRODUCTION_CHUNK_SIZE=50

AMQP_URI=amqp://guest:guest@localhost:5672
AMQP_QUEUE_PREFIX=h2-trust-dev-

DATABASE_URL=postgresql://admin:admin12345@localhost:5432/h2_trust?schema=public

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=h2-trust
KEYCLOAK_CLIENT_ID=h2-trust-bff
KEYCLOAK_CLIENT_SECRET=GumKpHmJsY5KCIe6e5TVi5gm1ALvykWY

CENTRALIZED_STORAGE_ENDPOINT_URL=http://localhost:9000
CENTRALIZED_STORAGE_REGION=us-east-1
CENTRALIZED_STORAGE_ACCESS_KEY=admin
CENTRALIZED_STORAGE_SECRET_KEY=admin12345
CENTRALIZED_STORAGE_BUCKET_NAME=h2-trust

########################
# Feature Verification #
########################

FEATURE_VERIFICATION_ENABLED=true

# Either ipfs-native or ipfs-pinning can be used as a DECENTRALIZED_STORAGE_PROVIDER for the verification feature.

# ipfs-native uses a local IPFS node for decentralized storage via docker-compose.
DECENTRALIZED_STORAGE_PROVIDER=ipfs-native
DECENTRALIZED_STORAGE_ENDPOINT_URL=http://localhost:5001
DECENTRALIZED_STORAGE_EXPLORER_URL="https://explore.ipld.io/#/explore"

# ipfs-pinning uses a third-party IPFS pinning service for decentralized storage.
DECENTRALIZED_STORAGE_PROVIDER=ipfs-pinning
DECENTRALIZED_STORAGE_ENDPOINT_URL=YOUR_ENDPOINT
DECENTRALIZED_STORAGE_EXPLORER_URL=YOUR_EXPLORER_URL
DECENTRALIZED_STORAGE_REGION=YOUR_REGION
DECENTRALIZED_STORAGE_ACCESS_KEY=YOUR_ACCESS_KEY
DECENTRALIZED_STORAGE_SECRET_KEY=YOUR_SECRET_KEY
DECENTRALIZED_STORAGE_BUCKET_NAME=YOUR_BUCKET_NAME

BLOCKCHAIN_ENDPOINT_URL=http://localhost:8545
BLOCKCHAIN_EXPLORER_URL=http://localhost:8545/explorer/tx
BLOCKCHAIN_PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63                      # genesis private key (account in docker/blockchain/genesis.json)
BLOCKCHAIN_ARTIFACT_PATH=libs/blockchain/smart-contract/artifacts/contracts/ProofStorage.sol/ProofStorage.json # compiled contract artifact path
BLOCKCHAIN_SMART_CONTRACT_ADDRESS=0x42699A7612A82f1d9C36148af9C77354759b210b                                   # deployed contract on local blockchain
