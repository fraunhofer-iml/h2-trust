generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  street     String
  postalCode String
  city       String
  state      String
  country    String
  latitude   Decimal? @db.Decimal(8, 6)
  longitude  Decimal? @db.Decimal(9, 6)

  companies Company[]
  units     Unit[]
}

model Document {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileName String

  unit   Unit?   @relation(fields: [unitId], references: [id])
  unitId String?

  processStep   ProcessStep? @relation(fields: [processStepId], references: [id])
  processStepId String?
}

model CsvImport {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String

  csvDocuments      CsvDocument[]
  stagedProductions StagedProduction[]
}

model CsvDocument {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileName        String
  type            String
  startedAt       DateTime
  endedAt         DateTime
  amount          Decimal  @db.Decimal(18, 6)
  transactionHash String?

  csvImport   CsvImport @relation(fields: [csvImportId], references: [id])
  csvImportId String
}

model Company {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type        String
  name        String
  mastrNumber String @unique

  address   Address @relation(fields: [addressId], references: [id])
  addressId String

  hydrogenAgreements    PowerPurchaseAgreement[] @relation(name: "HydrogenProducer")
  powerAgreements       PowerPurchaseAgreement[] @relation(name: "PowerProducer")
  unitOwners            Unit[]                   @relation(name: "UnitOwner")
  unitOperators         Unit[]                   @relation(name: "UnitOperator")
  stageProductionOwners StagedProduction[]       @relation(name: "StageProductionOwner")
  users                 User[]
  batches               Batch[]
}

model User {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  email String @unique

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  processSteps            ProcessStep[]
  csvImports              CsvImport[]
  decisions               PowerPurchaseAgreementDecision[]
  powerPurchaseAgreements PowerPurchaseAgreement[]
}

model Unit {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type           String // "power", "hydrogen", "compressor", "transport", "bottling", "storage", "endconsumer"
  name           String
  manufacturer   String
  modelType      String
  modelNumber    String
  serialNumber   String   @unique
  certifiedBy    String
  commissionedOn DateTime
  active         Boolean  @default(true)

  address   Address @relation(fields: [addressId], references: [id])
  addressId String

  owner   Company @relation(name: "UnitOwner", fields: [ownerId], references: [id])
  ownerId String

  operator   Company @relation(name: "UnitOperator", fields: [operatorId], references: [id])
  operatorId String

  specification   UnitSpecification @relation(fields: [specificationId], references: [id])
  specificationId String            @unique

  // Relations
  documents               Document[]
  processSteps            ProcessStep[]
  stagedProductions       StagedProduction[]
  powerPurchaseAgreements PowerPurchaseAgreement[]
  decisions               PowerPurchaseAgreementDecision[]
}

model UnitSpecification {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Power Production
  powerProductionType      String?
  biddingZone              String?
  ratedPower               Decimal?  @db.Decimal(18, 6)
  decommissioningPlannedOn DateTime?
  financialSupportReceived Boolean?
  energySource             String?

  // Hydrogen Production
  method     String?
  technology String?

  // Transport
  transportMode String?
  fuelType      String?

  // Storage
  storageType String?
  capacity    Decimal? @db.Decimal(18, 6)
  unit        Unit?
}

model Batch {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type   String
  amount Decimal @db.Decimal(18, 6)
  active Boolean @default(true)

  owner   Company @relation(fields: [ownerId], references: [id])
  ownerId String

  qualityDetails QualityDetails?
  processStep    ProcessStep?

  predecessors Batch[] @relation("BatchRelation")
  successors   Batch[] @relation("BatchRelation")
}

model QualityDetails {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Emission Data
  rfnboType          String
  powerType          String
  usedRenewablePower Decimal? @db.Decimal(18, 6)
  usedGridPower      Decimal? @db.Decimal(18, 6)
  distance           Decimal? @db.Decimal(8, 3)

  batch   Batch  @relation(fields: [batchId], references: [id])
  batchId String @unique
}

model ProcessStep {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type      String
  startedAt DateTime
  endedAt   DateTime

  batch   Batch  @relation(fields: [batchId], references: [id])
  batchId String @unique

  recordedBy User   @relation(fields: [userId], references: [id])
  userId     String

  executedBy Unit   @relation(fields: [unitId], references: [id])
  unitId     String

  documents Document[]
}

model PowerPurchaseAgreement {
  id        String    @id @default(uuid(7))
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  status    String
  validFrom DateTime
  validTo   DateTime

  requestingUser   User   @relation(fields: [requestingUserId], references: [id])
  requestingUserId String

  requestedCompany   Company @relation(fields: [requestedCompanyId], references: [id], name: "PowerProducer")
  requestedCompanyId String

  hydrogenProducer   Company @relation(fields: [hydrogenProducerId], references: [id], name: "HydrogenProducer")
  hydrogenProducerId String

  powerProductionUnit   Unit?   @relation(fields: [powerProductionUnitId], references: [id])
  powerProductionUnitId String?

  decision PowerPurchaseAgreementDecision?
}

model PowerPurchaseAgreementDecision {
  id        String   @id @default(uuid(7))
  decidedAt DateTime
  comment   String?

  powerPurchaseAgreement   PowerPurchaseAgreement @relation(fields: [powerPurchaseAgreementId], references: [id])
  powerPurchaseAgreementId String                 @unique

  decidingUser User   @relation(fields: [userId], references: [id])
  userId       String

  grantedPowerProductionUnit   Unit?   @relation(fields: [grantedPowerProductionUnitId], references: [id])
  grantedPowerProductionUnitId String?
}

model StagedProduction {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  amountProduced Decimal  @db.Decimal(18, 6)
  powerConsumed  Decimal  @db.Decimal(18, 6)
  startedAt      DateTime
  endedAt        DateTime
  type           String
  active         Boolean  @default(true)

  csvImport   CsvImport @relation(fields: [csvImportId], references: [id])
  csvImportId String

  productionUnit Unit   @relation(fields: [unitId], references: [id])
  unitId         String

  owner   Company @relation(name: "StageProductionOwner", fields: [ownerId], references: [id])
  ownerId String
}
