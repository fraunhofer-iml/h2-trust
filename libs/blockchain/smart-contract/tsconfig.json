{
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": [
      "es2025"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2025",
    "types": [
      "node",
      "mocha"
    ],
    "verbatimModuleSyntax": true
  }
}