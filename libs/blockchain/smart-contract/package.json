{
  "name": "smart-contract",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npx hardhat compile",
    "clean": "rm -rf ./artifacts ./cache ./typechain ./types",
    "deploy-local": "npx hardhat run scripts/deploy.ts --network local",
    "deploy-private": "npx hardhat run scripts/deploy.ts --network private",
    "deploy-public": "npx hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "test": "npx hardhat test",
    "typecheck": "npx tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.8",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.4",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "chai": "^5.3.3",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "forge-std": "github:foundry-rs/forge-std#v1.16.0",
    "hardhat": "^3.3.0",
    "mocha": "^11.7.5",
    "typescript": "~6.0.3"
  }
}
